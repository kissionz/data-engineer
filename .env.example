OPENAI_API_KEY=sk-your-key
OPENAI_MODEL=gpt-4.1
OPENAI_BASE_URL=https://api.openai.com/v1

# API style: "responses" for OpenAI native, "chat_completions" for compatible APIs (DeepSeek, etc.)
# Auto-detected based on base URL if not set (non-OpenAI URLs default to chat_completions)
# OPENAI_API_STYLE=chat_completions

# Bash is sandboxed with Docker when available. It never falls back to host.
HARNESS_BASH_SANDBOX=auto
HARNESS_SANDBOX_IMAGE=node:22-bookworm
HARNESS_SANDBOX_PULL=never
HARNESS_SANDBOX_NETWORK=none
