{
  "version": 1,
  "envFile": "/absolute/path/to/trusted/harness.env",
  "model": {
    "provider": "openai",
    "name": "gpt-4.1",
    "baseUrl": "https://api.openai.com/v1"
  },
  "budget": {
    "maxTurns": 50,
    "maxWallTimeMs": 1800000,
    "maxInputTokens": 1000000,
    "maxOutputTokens": 250000,
    "maxToolCalls": 200,
    "maxModelRetries": 3
  },
  "compaction": {
    "maxRecentEvents": 30,
    "eventThreshold": 60,
    "fallbackTokenThreshold": 24000,
    "contextWindowRatio": 0.6
  },
  "memory": {
    "enabled": true
  },
  "telemetry": {
    "enabled": true
  },
  "httpFetch": {
    "enabled": false,
    "allowedHosts": [],
    "allowedPorts": [443],
    "allowHttpLocalhost": false,
    "maxRedirects": 3,
    "maxResponseBytes": 1000000,
    "timeoutMs": 30000
  },
  "mcpServers": [
    {
      "id": "maxcompute",
      "enabled": false,
      "transport": {
        "type": "http",
        "url": "https://mcp.cn-hangzhou.maxcompute.aliyun.com/mcp",
        "allowedHosts": [
          "mcp.cn-hangzhou.maxcompute.aliyun.com"
        ],
        "auth": {
          "type": "oauth",
          "redirectMode": "browser"
        }
      },
      "timeoutMs": 30000,
      "maxTools": 128,
      "maxResources": 64,
      "maxPrompts": 64
    }
  ]
}
